{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "https://fuzzy-dulce-gondo-94f756ed.koyeb.app/$1"
    },
    {
      "src": "^/(.*\\.(js|css|map|json|png|jpg|jpeg|gif|svg|ico|woff2?|ttf))$",
      "dest": "/$1"
    },
    {
      "src": "^/service-worker.js$",
      "dest": "/service-worker.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
